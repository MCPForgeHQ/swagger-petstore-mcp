# Swagger Petstore MCP — environment variables
# Copy this file to .env and fill in your values

# MCPForge endpoint for this MCP server
# Get your endpoint from https://mcpforge.tech/dashboard
MCP_ENDPOINT=https://www.mcpforge.tech/api/servers/swagger-petstore-openapi-3-0-susoj

# MCPForge API key (required for private servers; not needed for this public demo)
# Generate one at https://mcpforge.tech/dashboard -> Settings -> API Keys
MCPFORGE_API_KEY=
